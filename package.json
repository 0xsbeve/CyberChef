{
  "name": "Saleh eChef",
  "version": "10.19.5",
  "description": "The Cyber Swiss Army Knife - a web app for encryption, encoding, compression and data analysis",
  "main": "src/node/index.mjs",
  "type": "module",f",
  "exports": {
    ".": {
      "import": "./src/node/index.mjs"
    }
  },
  "scripts": {
    "start": "grunt dev",
    "build": "grunt prod",
    "build:node": "grunt node",
    "test": "npm run test:config && npm run test:node && npm run test:browser",
    "test:config": "grunt configTests",
    "test:browser": "grunt testui",
    "test:node": "node --experimental-modules --experimental-json-modules --no-warnings tests/node/index.mjs",
    "test:node:consumer": "npm run build:node && grunt testnodeconsumer",
    "lint": "eslint --config eslint.config.mjs .",
    "docs": "esdoc -c esdoc.json",
    "prepare": "npm run build:node",
    "prepublishOnly": "npm test && npm run lint",
    "preversion": "npm run lint",
    "postversion": "git push && git push --tags",
    "newop": "node --experimental-modules --experimental-json-modules --no-warnings src/core/config/scripts/newOperation.mjs",
    "analyze": "webpack-bundle-analyzer build/prod/stats.json",
    "docker": "docker build -t Saleh eChef .",
    "docker:run": "docker run -p 8080:80 Saleh eChef"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gchq/Saleh eChef.git"
  },
  "keywords": [
    "cipher",
    "Saleh eChef",
    "data manipulation",
    "data analysis",
    "parse",
    "decode",
    "encode",
    "encrypt",
    "decrypt",
    "compress",
    "decompress",
    "transform",
    "data format"
  ],
